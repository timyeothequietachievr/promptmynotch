# Server-only — Payhip API (coupons, license keys)
# https://payhip.com/account/settings/developer
PAYHIP_API_KEY=

# Public — product key from Payhip → Products → Share/Embed
# Product: https://payhip.com/b/HZSW8
# Dashboard: https://payhip.com/account/products
NEXT_PUBLIC_PAYHIP_PRODUCT_KEY=HZSW8

# Optional — full checkout URL override (skips product-key construction)
# NEXT_PUBLIC_PAYHIP_CHECKOUT_URL=https://payhip.com/b/HZSW8

# Default true — sends users straight to checkout (email + custom questions)
NEXT_PUBLIC_PAYHIP_DIRECT_CHECKOUT=true

# PostHog — project API token (starts with phc_)
# Project settings: https://us.posthog.com/project/settings
# Docs: https://posthog.com/docs/libraries/next-js
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Search Console — HTML tag verification (content value only, not the full meta tag)
# Search Console: https://search.google.com/search-console
# Verification help: https://support.google.com/webmasters/answer/9008080
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 — Measurement ID (format G-XXXXXXXXXX)
# Open GA: https://analytics.google.com/analytics/web/
# Then: Admin (gear) → Data collection and modification → Data streams → your web stream → Measurement ID
# How to find it: https://support.google.com/analytics/answer/12200327
NEXT_PUBLIC_GA_MEASUREMENT_ID=
